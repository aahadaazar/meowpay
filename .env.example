# Backend
# Use the Supabase Session Pooler JDBC string. The direct 5432 endpoint can be IPv6-only.
SUPABASE_DB_URL=jdbc:postgresql://aws-0-region.pooler.supabase.com:5432/postgres?user=postgres.PROJECT_REF&password=YOUR_DB_PASSWORD
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret
# Optional: set instead of SUPABASE_JWT_SECRET if the Supabase project uses JWKS/asymmetric signing.
SUPABASE_JWT_JWK_SET_URI=
GROQ_API_KEY=replace-with-groq-api-key
GROQ_INSIGHT_MODEL=llama-3.3-70b-versatile
TOPUP_MAX=1000
CORS_ALLOWED_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# e2e only — leave both unset/false outside a Playwright run (see e2e/README.md).
# E2E_TEST_MODE unlocks POST /api/test/login, a password-login bypass for automated tests.
# Never set E2E_TEST_MODE=true in a deployed environment.
E2E_TEST_MODE=false
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
